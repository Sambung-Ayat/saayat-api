# App Config
PORT=8081
NODE_ENV=development # Options: development, testing, production
LOG_LEVEL=debug # Options: error, warn, info, debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=saayat_db
DB_SYNC=false # Set to true only in development, never in production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
BETTER_AUTH_SECRET=better-auth-secret-key
BETTER_AUTH_URL=http://localhost:8081
FRONTEND_URL=https://dev.saayat.site,http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google-client-secret-key

# Challenge Secret
CHALLENGE_SECRET=challenge-secret-key